# Backend
DATABASE_URL=postgresql://user:password@localhost:5432/claude_town
REDIS_URL=redis://localhost:6379
HELIUS_API_KEY=your-helius-api-key
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
TOKEN_MINT_ADDRESS=your-token-mint-address
TICK_INTERVAL_MS=30000
PORT=3001
CORS_ORIGIN=http://localhost:5173,https://evolving-clawd-town.xyz
ADMIN_PASSWORD=your-admin-password

# AI / Image Generation
AI_ENABLED=true
CLAWD_MODEL=gemini-2.0-flash-001

# Vertex AI (free $300 trial)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
